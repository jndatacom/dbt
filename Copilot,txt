SQL query run against the VBYOD source database
SELECT
    o.name AS TableName,
    i.name AS PrimaryKeyName,
    c.name AS ColumnName,
    ic.index_column_id AS ColumnPosition
FROM
    sys.objects o
INNER JOIN
    sys.indexes i ON i.object_id = o.object_id
INNER JOIN
    sys.index_columns ic ON ic.object_id = i.object_id AND ic.index_id = i.index_id
INNER JOIN
    sys.columns c ON c.object_id = ic.object_id AND c.column_id = ic.column_id
WHERE
    o.is_ms_shipped = 0 -- Filter out system tables
    AND i.is_primary_key = 1
    --AND o.name = 'YourTableName' -- Replace 'YourTableName' with the actual table name
ORDER BY
    o.name,
    ic.index_column_id;

