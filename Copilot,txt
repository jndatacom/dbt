The Dbt snapshot SQL file snap_account.sql is:
{% snapshot snap_account %}
with 
    source as (
        select
            accountcd,
            accountclassid,
            accountgroupid,
            accountid,
            active,
            allowmanualentry,
            box1099,
            coaorder,
            controlaccountmodule,
            createdbyid,
            createdbyscreenid,
            createddatetime,
            curyid,
            description,
            directpost,
            glconsolaccountcd,
            iscashaccount,
            lastmodifiedbyid,
            lastmodifiedbyscreenid,
            lastmodifieddatetime,
            nosubdetail,
            noteid,
            postoption,
            requireunits,
            revalcuryratetypeid,
            taxcategoryid,
            type,
            deleteddatabaserecord
        from {{ source('vebyod', 'account') }}
        where accountid is not null
    ),
    dedup as (
        select
            *
            , row_number() over (partition by accountid order by lastmodifieddatetime desc) as row_num
        from source
    ),
    final as (
        select
            {{ dbt_utils.generate_surrogate_key(['accountid']) }} as account_key,
            accountcd,
            accountclassid,
            accountgroupid,
            accountid,
            active,
            allowmanualentry,
            box1099,
            coaorder,
            controlaccountmodule,
            createdbyid,
            createdbyscreenid,
            createddatetime,
            curyid,
            description,
            directpost,
            glconsolaccountcd,
            iscashaccount,
            lastmodifiedbyid,
            lastmodifiedbyscreenid,
            lastmodifieddatetime,
            nosubdetail,
            noteid,
            postoption,
            requireunits,
            revalcuryratetypeid,
            taxcategoryid,
            type,
            deleteddatabaserecord
        from dedup
        where row_num = 1
    )
    select *
    from final
{% endsnapshot %}

